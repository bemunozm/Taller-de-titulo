# Server Port
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5455
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=developDB

# JWT Configuration (auth propio — en migración a better-auth)
JWT_SECRET=your_super_secret_jwt_key_here

# better-auth (Fase 0 — ver docs/modulos/auth-multitenant.md)
# Genera el secret en prod con: openssl rand -base64 32
BETTER_AUTH_SECRET=your_better_auth_secret_min_32_chars
# URL propia del backend donde better-auth monta /api/auth (NO la del frontend)
BETTER_AUTH_URL=http://localhost:3000

# SMTP Configuration for Email Service
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-email-password

# Frontend URL for email links
FRONTEND_URL=http://localhost:5173

# OpenAI Configuration for Digital Concierge
OPENAI_API_KEY=sk-your-openai-api-key-here

# Hub Configuration (Raspberry Pi)
HUB_SECRET=your_super_secret_hub_key_change_in_production_12345

# Cloudinary Configuration for Image Upload
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
